<?xml version="1.0"?>
<view icon="5000" title="NB3 Options" left="75" top="50" width="270" height="290">
	<control progid="DecalControls.FixedLayout">
		<!-- Split -->
		<control progid="DecalControls.PushButton" left="0" top="0" width="270" height="2" text="-" />
		<!-- Header: Character GUID and name -->
		<control progid="DecalControls.StaticText" left="2" top="2" width="68" height="15" text="Character:" fontface="Arial" fontsize="14" textcolor="0" fontstyle="bold" />
		<control progid="DecalControls.StaticText" name="staticGUIDName" left="72" top="2" width="194" height="18" text="(0x00000000)" fontface="Arial" fontsize="14" textcolor="128" fontstyle="normal" />
		<!-- Split -->
		<control progid="DecalControls.PushButton" left="0" top="17" width="270" height="2" text="-" />
		<!-- Healing Kits -->
		<control progid="DecalControls.StaticText" left="2" top="19" width="200" height="15" text="Healing Kits to use" fontface="Arial" fontsize="14" textcolor="0" fontstyle="bold" />
		<control progid="DecalControls.Checkbox" name="checkboxUsePlentiful" left="2" top="35" width="80" height="15" text="Plentiful" fontface="Arial" fontsize="14" textcolor="0" fontstyle="normal" />
		<control progid="DecalControls.Checkbox" name="checkboxUseTreated" left="92" top="35" width="75" height="15" text="Treated" fontface="Arial" fontsize="14" textcolor="0" fontstyle="normal" />
		<control progid="DecalControls.Checkbox" name="checkboxUsePeerless" left="182" top="35" width="75" height="15" text="Peerless" fontface="Arial" fontsize="14" textcolor="0" fontstyle="normal" />
		<!-- Split -->
		<control progid="DecalControls.PushButton" left="0" top="50" width="270" height="2" text="-" />
		<!-- Level 7 Spells -->
		<control progid="DecalControls.StaticText" left="2" top="52" width="140" height="15" text="Level 7 Spells" fontface="Arial" fontsize="14" textcolor="0" fontstyle="bold" />
		<control progid="DecalControls.Checkbox" name="checkboxUseRevit7" left="2" top="68" width="94" height="15" text="Use Revit 7" fontface="Arial" fontsize="14" textcolor="0" fontstyle="normal" />
		<control progid="DecalControls.Checkbox" name="checkboxUseS2M7" left="100" top="68" width="76" height="15" text="Use S2M7" fontface="Arial" fontsize="14" textcolor="0" fontstyle="normal" />
		<control progid="DecalControls.Checkbox" name="checkboxUseH2M7" left="180" top="68" width="76" height="15" text="Use H2M7" fontface="Arial" fontsize="14" textcolor="0" fontstyle="normal" />
		<control progid="DecalControls.Checkbox" name="checkboxFallbackTo6" left="2" top="84" width="266" height="15" text="Use level 6 if level 7 unknown" fontface="Arial" fontsize="14" textcolor="0" fontstyle="normal" />
		<!-- Split -->
		<control progid="DecalControls.PushButton" left="0" top="99" width="270" height="2" text="-" />
		<!-- Aggressivity Rating -->
		<control progid="DecalControls.StaticText" left="2" top="102" width="162" height="15" text="Expected % of Spell Cost" fontface="Arial" fontsize="14" textcolor="0" fontstyle="bold" />
		<control progid="DecalControls.Edit" name="editAR" left="170" top="101" width="40" height="15" marginx="3" marginy="1" text="-AR-" imagebrushsrc="1067120" fontface="Arial" fontsize="14" textcolor="10079487" fontstyle="bold" />
		<!-- Split -->
		<control progid="DecalControls.PushButton" left="0" top="116" width="270" height="2" text="-" />
		<!-- Mana Regeneration Mode -->
		<control progid="DecalControls.StaticText" left="2" top="119" width="200" height="15" text="Mana Regeneration Mode" fontface="Arial" fontsize="14" textcolor="0" fontstyle="bold" />
		<control progid="DecalControls.Choice" ID="3201" name="choiceManaMode" left="2" top="134" width="266" height="18" droplines="8" selected="6">
			<option data="0" text="(None - no mana regen)" />
			<option data="1" text="Drink Trade Mana Elixirs" />
			<option data="2" text="Drink Stamina Elixirs / Cast S2M" />
			<option data="3" text="Rest for Stamina / Cast S2M" />
			<option data="4" text="Heal with Healing Kits / Cast H2M" />
			<option data="5" text="Cast Revitalize / Cast S2M" />
			<option data="6" text="Spells: S2M + Cannibalize + Revitalize" />
		</control>
		<!-- Split (was the Mana/Editor-scheme divider; the Editor Color Scheme control was
		     retired in v3.0.7 and the layout below re-flowed up, so this now divides Mana
		     Regeneration Mode from Quiet Mode) -->
		<control progid="DecalControls.PushButton" left="0" top="155" width="270" height="2" text="-" />
		<!-- Quiet Mode -->
		<control progid="DecalControls.Checkbox" name="checkboxQuietMode" left="2" top="159" width="260" height="15" text="Reduced chat output while buffing" fontface="Arial" fontsize="14" textcolor="0" fontstyle="normal" />
		<control progid="DecalControls.Checkbox" name="checkboxEditorPermaDelete" left="2" top="175" width="260" height="15" text="Permanently delete files in editor" fontface="Arial" fontsize="14" textcolor="0" fontstyle="normal" />

		<!-- Split -->
		<control progid="DecalControls.PushButton" left="0" top="191" width="270" height="2" text="-" />
		<!-- Aggressivity Rating -->
		<control progid="DecalControls.StaticText" left="2" top="195" width="216" height="15" text="Max level for H2M, S2M and Revit" fontface="Arial" fontsize="14" textcolor="0" fontstyle="bold" />
		<control progid="DecalControls.Edit" name="editMaxSpellLevel" left="227" top="194" width="40" height="15" marginx="3" marginy="1" text="-AR-" imagebrushsrc="1067120" fontface="Arial" fontsize="14" textcolor="10079487" fontstyle="bold" />

		<!-- Split -->
		<control progid="DecalControls.PushButton" left="0" top="210" width="270" height="2" text="-" />
		<!-- Min cast chance threshold: with the skill-based level cap on (default), each buff uses
		     the HIGHEST level whose predicted cast chance is at least this % — the "barely able to
		     reach" knob. Lower it to push higher levels (more fizzles); raise it to play safe. 90 default. -->
		<control progid="DecalControls.StaticText" left="2" top="214" width="216" height="15" text="Min cast chance % (barely reach)" fontface="Arial" fontsize="14" textcolor="0" fontstyle="bold" />
		<control progid="DecalControls.Edit" name="editMinCast" left="227" top="213" width="40" height="15" marginx="3" marginy="1" text="-AR-" imagebrushsrc="1067120" fontface="Arial" fontsize="14" textcolor="10079487" fontstyle="bold" />
		<!-- Optional potions fallback for the spell-recovery mode (kits are the other optional
		     fallback, driven by the Healing Kits checkboxes above) -->
		<control progid="DecalControls.Checkbox" name="checkboxUsePotions" left="2" top="231" width="262" height="15" text="Use potions as optional fallback" fontface="Arial" fontsize="14" textcolor="0" fontstyle="normal" />
		<!-- Split -->
		<control progid="DecalControls.PushButton" left="0" top="249" width="270" height="2" text="-" />
		<!-- Dismiss and Save button -->
		<control progid="DecalControls.PushButton" name="pbOptDismiss" ID="4202" left="3" top="253" width="66" height="21" text="Dismiss" fontface="Arial" fontsize="15" textcolor="10079487" fontstyle="bold" />
		<control progid="DecalControls.PushButton" name="pbSave" ID="4201" left="200" top="253" width="66" height="21" text="Save" fontface="Arial" fontsize="15" textcolor="10079487" fontstyle="bold" />
	</control>
</view>
